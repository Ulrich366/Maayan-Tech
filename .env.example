# ============================================================
# MAAYAN - Intelligent Water Leak Detection System
# Environment Variables
# ============================================================

# Application
APP_NAME=Maayan
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Authentication (operator dashboard access)
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=Maayan@2026
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=480

# Database
DATABASE_URL=sqlite:///./maayan.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/maayan_db

# LLM for report explanations — Groq is used first if set (free tier,
# get a key at console.groq.com), falling back to OpenAI if GROQ_API_KEY
# is absent, falling back further to a rule-based template if neither is set.
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024

# Simulation
# Which simulated city network loads at startup — "douala" or "bafoussam".
# Switchable live afterwards from the dashboard (Settings page / header),
# no restart required.
DEFAULT_CITY=douala
SIMULATION_INTERVAL_SECONDS=2
DEFAULT_SCENARIO=normal

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# MQTT (Phase 2 IoT — ESP32 + LoRa gateways)
# Set MQTT_ENABLED=true and point at your broker to ingest live sensor data.
# HTTP ingest (POST /api/iot/telemetry) works without MQTT.
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USER=
MQTT_BROKER_PASSWORD=
MQTT_TOPIC_PREFIX=maayan/sensors
IOT_STALE_SECONDS=120
# Optional API key for POST /api/iot/telemetry (X-Maayan-Key header)
IOT_INGEST_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/maayan.log

# Continuous ML learning — models retrain as new labeled data accumulates
ML_CONTINUOUS_LEARNING=true
ML_RETRAIN_MIN_SAMPLES=50
ML_SAMPLE_INTERVAL_SECONDS=30
ML_MIN_TRAINING_SAMPLES=80
